rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Require a valid Firebase Authentication session for every operation.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Retrieve the authenticated user's role from the userRoles collection,
    // falling back to appUsers when no userRoles document exists.
    // Returns '' when neither document has been created yet, keeping the app
    // functional during initial Firebase setup.
    function userRole() {
      return exists(/databases/$(database)/documents/userRoles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.get('role', '')
        : exists(/databases/$(database)/documents/appUsers/$(request.auth.uid))
          ? get(/databases/$(database)/documents/appUsers/$(request.auth.uid)).data.get('role', '')
          : '';
    }

    // Roles with write permission: admin, genesis, branch.
    // An empty role (no userRoles document yet) is also allowed so the app
    // remains functional before per-user roles are configured.
    function canWrite() {
      let role = userRole();
      return role == '' || role == 'admin' || role == 'genesis' || role == 'branch';
    }

    // The userRoles collection maps Firebase UID → role string.
    // Only admins may write role documents; users may only read their own.
    match /userRoles/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && userRole() == 'admin';
    }

    match /members/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /visitors/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /leaders/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /tithes/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /prayers/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /sermons/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /events/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /attendance/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /volunteers/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    // appUsers stores user profiles (username, displayName, role) linked by Firebase UID.
    // Any authenticated user may read their own profile; only admins may list or write.
    // A user may also create their own profile document when none exists yet (bootstrap),
    // allowing the first admin to seed their role before any Firestore documents are in place.
    // The role written during self-create must be a known application role.
    // Updates and deletes remain admin-only to prevent role self-escalation.
    match /appUsers/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || userRole() == 'admin');
      allow create: if isAuthenticated() && (
        userRole() == 'admin' ||
        (request.auth.uid == uid &&
          request.resource.data.role in ['admin', 'genesis', 'branch', 'pastor'])
      );
      allow update, delete: if isAuthenticated() && userRole() == 'admin';
    }
  }
}
