rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Require a valid Firebase Authentication session for every operation.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Retrieve the authenticated user's role.
    // Primary source : Firebase ID token custom claim  token.role
    //                  (set server-side by the setUserRole / syncUserClaim
    //                   Cloud Functions — most secure, always up-to-date).
    // Fallback source: Firestore appUsers profile
    //                  (used during migration before custom claims are set).
    function userRole() {
      let tokenRole = request.auth.token.get('role', '');
      return tokenRole != ''
        ? tokenRole
        : (exists(/databases/$(database)/documents/appUsers/$(request.auth.uid))
            ? get(/databases/$(database)/documents/appUsers/$(request.auth.uid)).data.get('role', '')
            : '');
    }

    // Returns true when the token carries the boolean admin claim OR the
    // string role claim equals 'admin'.
    function isAdmin() {
      return request.auth.token.get('admin', false) == true || userRole() == 'admin';
    }

    // Roles with write permission: admin, genesis, branch.
    // An empty role (no claim / profile yet) is also allowed so the app
    // remains functional before per-user roles are configured.
    function canWrite() {
      let role = userRole();
      return role == '' || role == 'admin' || role == 'genesis' || role == 'branch';
    }

    // The userRoles collection maps Firebase UID → role string (legacy).
    // Only admins may write role documents; users may only read their own.
    match /userRoles/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if isAuthenticated() && isAdmin();
    }

    match /members/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /visitors/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /leaders/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /tithes/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /prayers/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /sermons/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /events/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /attendance/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /volunteers/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /expenses/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /payment_requisitions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /conference/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    match /conference_budget/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && canWrite();
    }

    // appUsers stores user profiles (username, displayName, role) linked by Firebase UID.
    // Any authenticated user may read their own profile; only admins may list or write.
    // A user may also create their own profile document when none exists yet (bootstrap),
    // allowing the first admin to seed their role before any custom claims are in place.
    // The role written during self-create must be a known application role.
    // Updates and deletes remain admin-only to prevent role self-escalation.
    match /appUsers/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow create: if isAuthenticated() && (
        isAdmin() ||
        (request.auth.uid == uid &&
          request.resource.data.role in ['admin', 'genesis', 'branch', 'pastor'])
      );
      allow update, delete: if isAuthenticated() && isAdmin();
    }
  }
}
